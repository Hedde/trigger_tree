{
  "description": "Collect local documentation-discovery telemetry without affecting Codex commands.",
  "hooks": {
    "SessionStart": [{"hooks": [{"type": "command", "command": "python3 \"${PLUGIN_ROOT}/scripts/tt-codex-hook.py\"", "commandWindows": "py -3 \"%PLUGIN_ROOT%\\scripts\\tt-codex-hook.py\"", "timeout": 5}]}],
    "UserPromptSubmit": [{"hooks": [{"type": "command", "command": "python3 \"${PLUGIN_ROOT}/scripts/tt-codex-hook.py\"", "commandWindows": "py -3 \"%PLUGIN_ROOT%\\scripts\\tt-codex-hook.py\"", "timeout": 5}]}],
    "PostToolUse": [{"matcher": "Bash|Read|Glob|Grep|mcp__.*(read|search|grep|find).*", "hooks": [{"type": "command", "command": "python3 \"${PLUGIN_ROOT}/scripts/tt-codex-hook.py\"", "commandWindows": "py -3 \"%PLUGIN_ROOT%\\scripts\\tt-codex-hook.py\"", "timeout": 5}]}],
    "Stop": [{"hooks": [{"type": "command", "command": "python3 \"${PLUGIN_ROOT}/scripts/tt-codex-hook.py\"", "commandWindows": "py -3 \"%PLUGIN_ROOT%\\scripts\\tt-codex-hook.py\"", "timeout": 5}]}]
  }
}
