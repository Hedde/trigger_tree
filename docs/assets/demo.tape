Output docs/assets/demo.gif

Set Shell "bash"
Set FontSize 16
Set Width 1200
Set Height 500
Set Padding 18
Set Framerate 12
Set PlaybackSpeed 1

Type "python3 scripts/tt-watch.py --demo"
Enter
Sleep 5s
Type "h"
Sleep 2s
Type "n"
Sleep 2s
Type "["
Sleep 2s
Type "]"
Sleep 2s
Type "a"
Sleep 1s
Type "s"
Sleep 2s
Type "2"
Sleep 2s
Type "s"
Sleep 1s
Type "q"
